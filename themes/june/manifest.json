{
    "version": "1.0.0",
    "description": "June theme manifest - defines available templates and their configurations",
    "templates": {
        "anchor": {
            "label": "Anchor Navigation",
            "description": "Sticky navigation bar linking to sections below (shows only page blocks after itself)",
            "component": "App\\Livewire\\Anchor",
            "view": "anchor",
            "displayOptions": {
                "cta_text": "Book a test drive",
                "cta_url": "/test-drive",
                "cta_icon": "fa-steering-wheel"
            },
            "displayOptionsDefinition": {
                "cta_text": { "type": "text", "label": "CTA Text", "default": "Book a test drive" },
                "cta_url": { "type": "url", "label": "CTA URL", "default": "/test-drive" },
                "cta_icon": { "type": "text", "label": "CTA Icon (Font Awesome class)", "default": "fa-steering-wheel" }
            },
            "styles": ["default"]
        },
        "article-list": {
            "label": "Article List",
            "description": "Display a list of articles with pagination",
            "component": "App\\Livewire\\ArticleList",
            "view": "article-list",
            "displayOptions": {
                "anchor_label": "Articles",
                "title": "Latest Articles",
                "subtitle": "Stay updated with our latest articles and news",
                "show_featured_image": true,
                "show_excerpt": true,
                "show_author": true,
                "show_date": true,
                "show_read_more": true,
                "read_more_text": "Read More",
                "layout": "grid"
            },
            "queryOptions": {
                "posts_per_page": 6,
                "category_filter": "",
                "tag_filter": "",
                "order_by": "published_at",
                "order_direction": "desc"
            },
            "displayOptionsDefinition": {
                "anchor_label": { "type": "text", "label": "Anchor Label", "default": "Articles" },
                "title": { "type": "text", "label": "Title", "default": "Latest Articles" },
                "subtitle": {
                    "type": "textarea",
                    "label": "Subtitle",
                    "default": "Stay updated with our latest articles and news"
                },
                "show_featured_image": { "type": "boolean", "label": "Show Featured Image", "default": true },
                "show_excerpt": { "type": "boolean", "label": "Show Excerpt", "default": true },
                "show_author": { "type": "boolean", "label": "Show Author", "default": true },
                "show_date": { "type": "boolean", "label": "Show Date", "default": true },
                "show_read_more": { "type": "boolean", "label": "Show Read More", "default": true },
                "read_more_text": { "type": "text", "label": "Read More Text", "default": "Read More" },
                "layout": {
                    "type": "select",
                    "label": "Layout",
                    "options": [
                        { "value": "grid", "label": "Grid" },
                        { "value": "list", "label": "List" }
                    ],
                    "default": "grid"
                }
            },
            "queryOptionsDefinition": {
                "posts_per_page": { "type": "number", "label": "Posts Per Page", "min": 1, "max": 50, "default": 6 },
                "category_filter": { "type": "text", "label": "Category Filter", "default": "" },
                "tag_filter": { "type": "text", "label": "Tag Filter", "default": "" },
                "order_by": {
                    "type": "select",
                    "label": "Order By",
                    "options": [
                        { "value": "published_at", "label": "Published Date" },
                        { "value": "title", "label": "Title" },
                        { "value": "created_at", "label": "Created Date" }
                    ],
                    "default": "published_at"
                },
                "order_direction": {
                    "type": "select",
                    "label": "Order Direction",
                    "options": [
                        { "value": "asc", "label": "Ascending" },
                        { "value": "desc", "label": "Descending" }
                    ],
                    "default": "desc"
                }
            },
            "styles": ["default"]
        },
        "dynamic-form": {
            "label": "Dynamic Form",
            "description": "Dynamic form with validation and submission",
            "component": "App\\Livewire\\DynamicForm",
            "view": "dynamic-form",
            "displayOptions": {
                "anchor_label": "Book a Test Drive",
                "title": "Test Drive Booking",
                "subtitle": "Book your test drive today",
                "description": "Fill out the form below and we'll get back to you as soon as possible.",
                "submit_text": "Book Test Drive",
                "success_title": "Thank You!",
                "success_message": "✅ Your test drive booking has been submitted. We'll contact you soon to confirm your appointment.",
                "layout": "form",
                "theme": "default",
                "columns": 1,
                "redirect_after_submit": ""
            },
            "queryOptions": {
                "form_slug": ""
            },
            "displayOptionsDefinition": {
                "anchor_label": { "type": "text", "label": "Anchor Label", "default": "Book a Test Drive" },
                "title": { "type": "text", "label": "Title", "default": "Test Drive Booking" },
                "subtitle": { "type": "text", "label": "Subtitle", "default": "Book your test drive today" },
                "description": {
                    "type": "textarea",
                    "label": "Description",
                    "default": "Fill out the form below and we'll get back to you as soon as possible."
                },
                "submit_text": { "type": "text", "label": "Submit Button Text", "default": "Book Test Drive" },
                "success_title": { "type": "text", "label": "Success Title", "default": "Thank You!" },
                "success_message": {
                    "type": "textarea",
                    "label": "Success Message",
                    "default": "✅ Your test drive booking has been submitted. We'll contact you soon to confirm your appointment."
                },
                "layout": {
                    "type": "select",
                    "label": "Layout",
                    "options": [{ "value": "form", "label": "Form" }],
                    "default": "form"
                },
                "theme": {
                    "type": "select",
                    "label": "Theme",
                    "options": [{ "value": "default", "label": "Default" }],
                    "default": "default"
                },
                "columns": { "type": "number", "label": "Columns", "min": 1, "max": 3, "default": 1 },
                "redirect_after_submit": { "type": "url", "label": "Redirect After Submit", "default": "" }
            },
            "queryOptionsDefinition": {
                "form_slug": {
                    "type": "text",
                    "label": "Form Slug",
                    "description": "Reference to the dynamic form to render",
                    "default": ""
                }
            },
            "styles": ["default", "interactive", "content"]
        },
