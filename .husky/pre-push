echo "🔍 Running pre-push checks..."
echo ""

# Colors for output (if terminal supports it)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored messages
print_error() {
    echo "${RED}❌ $1${NC}"
}

print_success() {
    echo "${GREEN}✅ $1${NC}"
}

print_info() {
    echo "${BLUE}ℹ️  $1${NC}"
}

print_warning() {
    echo "${YELLOW}⚠️  $1${NC}"
}

# Check if npm is available
if ! command -v npm >/dev/null 2>&1; then
    print_error "npm is not available. Please install Node.js and npm."
    exit 1
fi

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    print_error "Not in a git repository!"
    exit 1
fi

# Read ref information from stdin (pre-push hook standard)
# Format: <local-ref> <local-sha1> <remote-ref> <remote-sha1>
HAS_COMMITS_TO_PUSH=false
while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip if all zeros (deletion) or if local and remote are the same
    if [ "$local_sha" != "0000000000000000000000000000000000000000" ] && [ "$local_sha" != "$remote_sha" ]; then
        HAS_COMMITS_TO_PUSH=true
        break
    fi
done

# If no commits to push, skip checks
if [ "$HAS_COMMITS_TO_PUSH" = false ]; then
    print_info "No commits to push. Skipping checks."
    exit 0
fi

# Track if any check fails
FAILED=0
START_TIME=$(date +%s)

# Run TypeScript type check (show output only on failure)
echo "📝 Type checking TypeScript files..."
OUTPUT=$(npm run type-check:all 2>&1)
EXIT=$?
if [ $EXIT -ne 0 ]; then
    echo "$OUTPUT"
    print_error "TypeScript type check failed!"
    echo ""
    echo "💡 Fix the errors above, or run 'npm run type-check:all' to see them again."
    FAILED=1
fi
echo ""

# Run linters (show output only on failure)
echo "🧹 Running linters..."
OUTPUT=$(npm run lint:all 2>&1)
EXIT=$?
if [ $EXIT -ne 0 ]; then
    echo "$OUTPUT"
    print_error "Linting failed!"
    echo ""
    echo "💡 Fix the errors above, or run 'npm run lint:all:fix' to auto-fix."
    FAILED=1
fi
echo ""

# Validate Blade templates
# Set SKIP_BLADE_CHECK=1 to skip Blade template validation during pre-push
if [ -z "$SKIP_BLADE_CHECK" ]; then
    echo "🔍 Validating Blade templates..."
    
    # Detect Docker container name (try common Laradock workspace container names)
    WORKSPACE_CONTAINER=""
    if docker ps --format '{{.Names}}' | grep -q "^laradock-workspace-1$"; then
        WORKSPACE_CONTAINER="laradock-workspace-1"
    elif docker ps --format '{{.Names}}' | grep -q "^laradock_workspace_1$"; then
        WORKSPACE_CONTAINER="laradock_workspace_1"
    elif docker ps --format '{{.Names}}' | grep -qE "^.*workspace.*$"; then
        WORKSPACE_CONTAINER=$(docker ps --format '{{.Names}}' | grep -E "^.*workspace.*$" | head -1)
    fi
    
    if [ -n "$WORKSPACE_CONTAINER" ]; then
        # Run Blade validation inside Docker container (show output only on failure)
        OUTPUT=$(docker exec "$WORKSPACE_CONTAINER" bash -c "cd /var/www/appsolutely/site && php artisan view:clear && php artisan view:cache" 2>&1)
        EXIT=$?
        if [ $EXIT -eq 0 ]; then
            docker exec "$WORKSPACE_CONTAINER" bash -c "cd /var/www/appsolutely/site && php artisan view:clear" >/dev/null 2>&1
        else
            echo "$OUTPUT"
            print_error "Blade template validation failed!"
            echo ""
            echo "💡 Run 'docker exec $WORKSPACE_CONTAINER bash -c \"cd /var/www/appsolutely/site && php artisan view:cache\"' to see full errors."
            echo "💡 Or set SKIP_BLADE_CHECK=1 to skip Blade template validation during pre-push."
            FAILED=1
        fi
    else
        # Fallback: try to run on host (may fail if PHP/dependencies not available)
        if command -v php >/dev/null 2>&1; then
            print_warning "Docker container not found. Running Blade validation on host (may fail if dependencies are missing)."
            OUTPUT=$(php artisan view:clear && php artisan view:cache 2>&1)
            EXIT=$?
            if [ $EXIT -eq 0 ]; then
                php artisan view:clear >/dev/null 2>&1
            else
                echo "$OUTPUT"
                print_error "Blade template validation failed!"
                echo ""
                echo "💡 Run 'php artisan view:cache' to see full validation errors."
                echo "💡 Or set SKIP_BLADE_CHECK=1 to skip Blade template validation during pre-push."
                FAILED=1
            fi
        else
            print_warning "Docker container not found and PHP not available on host."
            print_warning "Skipping Blade template validation. Run manually: docker exec laradock-workspace-1 bash -c 'cd /var/www/appsolutely/site && php artisan view:cache'"
        fi
    fi
    echo ""
elif [ -n "$SKIP_BLADE_CHECK" ]; then
    print_info "Skipping Blade template validation (SKIP_BLADE_CHECK is set)"
    echo ""
fi

# Run frontend tests (Vitest) - show output only on failure
# Set SKIP_FRONTEND_TESTS=1 to skip frontend tests during pre-push
if [ -z "$SKIP_FRONTEND_TESTS" ]; then
    echo "🧪 Running frontend tests..."
    OUTPUT=$(npm run test:frontend 2>&1)
    EXIT=$?
    if [ $EXIT -ne 0 ]; then
        echo "$OUTPUT"
        print_error "Frontend tests failed!"
        echo ""
        echo "💡 Run 'npm run test:frontend' to see full test results."
        echo "💡 Or set SKIP_FRONTEND_TESTS=1 to skip frontend tests during pre-push."
        FAILED=1
    fi
    echo ""
elif [ -n "$SKIP_FRONTEND_TESTS" ]; then
    print_info "Skipping frontend tests (SKIP_FRONTEND_TESTS is set)"
    echo ""
fi

# Optional: Run PHP tests
# Set SKIP_PHP_TESTS=1 to skip PHP tests during pre-push
if [ -z "$SKIP_PHP_TESTS" ]; then
    echo "🧪 Running PHP tests..."
    
    # Detect Docker container name (try common Laradock workspace container names)
    WORKSPACE_CONTAINER=""
    if docker ps --format '{{.Names}}' | grep -q "^laradock-workspace-1$"; then
        WORKSPACE_CONTAINER="laradock-workspace-1"
    elif docker ps --format '{{.Names}}' | grep -q "^laradock_workspace_1$"; then
        WORKSPACE_CONTAINER="laradock_workspace_1"
    elif docker ps --format '{{.Names}}' | grep -qE "^.*workspace.*$"; then
        WORKSPACE_CONTAINER=$(docker ps --format '{{.Names}}' | grep -E "^.*workspace.*$" | head -1)
    fi
    
    if [ -n "$WORKSPACE_CONTAINER" ]; then
        # Run tests inside Docker container (show output only on failure)
        OUTPUT=$(docker exec "$WORKSPACE_CONTAINER" bash -c "cd /var/www/appsolutely/site && php artisan test --testdox" 2>&1)
        EXIT=$?
        if [ $EXIT -ne 0 ]; then
            echo "$OUTPUT"
            print_error "PHP tests failed!"
            echo ""
            echo "💡 Run 'docker exec $WORKSPACE_CONTAINER bash -c \"cd /var/www/appsolutely/site && php artisan test\"' to see full test results."
            echo "💡 Or set SKIP_PHP_TESTS=1 to skip PHP tests during pre-push."
            FAILED=1
        fi
    else
        # Fallback: try to run on host (may fail if PHP/dependencies not available)
        if [ -f "./vendor/bin/phpunit" ]; then
            print_warning "Docker container not found. Running PHP tests on host (may fail if dependencies are missing)."
            OUTPUT=$(./vendor/bin/phpunit --testdox 2>&1)
            EXIT=$?
            if [ $EXIT -ne 0 ]; then
                echo "$OUTPUT"
                print_error "PHP tests failed!"
                echo ""
                echo "💡 Run './vendor/bin/phpunit' to see full test results."
                echo "💡 Or set SKIP_PHP_TESTS=1 to skip PHP tests during pre-push."
                FAILED=1
            fi
        else
            print_warning "Docker container not found and PHPUnit not available on host."
            print_warning "Skipping PHP tests. Run tests manually: docker exec laradock-workspace-1 bash -c 'cd /var/www/appsolutely/site && php artisan test'"
        fi
    fi
    echo ""
elif [ -n "$SKIP_PHP_TESTS" ]; then
    print_info "Skipping PHP tests (SKIP_PHP_TESTS is set)"
    echo ""
fi

# Calculate duration
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

# Final result
if [ $FAILED -eq 1 ]; then
    echo ""
    print_error "Pre-push checks failed! (took ${DURATION}s)"
    echo ""
    echo "💡 Fix the errors above before pushing."
    echo "💡 Or use 'git push --no-verify' to skip (not recommended)."
    exit 1
fi

print_success "All pre-push checks passed! (took ${DURATION}s)"
exit 0
